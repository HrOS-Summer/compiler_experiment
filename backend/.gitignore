# --- Node & Express Backend .gitignore ---

# Node modules
node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Build output
dist/
build/

# Debug files
*.pid
*.seed
*.pid.lock

# Coverage/testing
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo

# PM2 logs
.pids
.pm2/logs/*.log
.pm2/pids/*.pid
.pm2/*-error.log
.pm2/*-out.log

# IDE settings
.vscode/
.idea/

# Temporary folders
tmp/
temp/

# Optional: Ignore Swagger auto-generated JSON
swagger.json